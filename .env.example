# Optional — only needed for Redis-backed cost tracking
REDIS_URL=redis://localhost:6379

# Optional — only needed for audit logging
DATABASE_URL=postgresql://user:password@localhost:5432/ai_shield

# Optional — only needed if using @ai-shield/openai wrapper
OPENAI_API_KEY=sk-...

# Optional — only needed if using @ai-shield/anthropic wrapper
ANTHROPIC_API_KEY=sk-ant-...
